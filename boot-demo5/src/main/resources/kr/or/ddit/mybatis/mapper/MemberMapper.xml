<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.ddit.member.mapper.MemberMapper">
  <resultMap type="kr.or.ddit.dto.MemberDTO" id="memberMap" autoMapping="true">
    <id property="memId" column="mem_id" />
    <collection property="memRoles" javaType="java.util.List" ofType="java.lang.String">
      <result column="role_name" />
    </collection>
  </resultMap>

  <select id="selectMember" resultMap="memberMap"> 
    select m.*, mr.role_name 
    from member m 
     inner join member_role mr on ( m.mem_id = mr.mem_id ) 
    where m.mem_id = #{memId} 
  </select>

</mapper>