<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.lprod.mapper.LprodMapper">

    <!-- selectLprodList -->
    <select id="selectLprodList" resultType="com.example.demo.dto.LprodDto">
        SELECT LPROD_ID, LPROD_GU, LPROD_NAME
        FROM LPROD
        ORDER BY LPROD_ID
    </select>

</mapper>
