<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="https://jakarta.ee/xml/ns/jakartaee"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
	version="6.0">
	<display-name>worldtime-web</display-name>
	<welcome-file-list>
		<welcome-file>worldtime</welcome-file>
	</welcome-file-list>

	<servlet>
		<servlet-name>WorldTimeServlet</servlet-name>
		<servlet-class>com.homework.web.WorldTimeServlet</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>WorldTimeServlet</servlet-name>
		<url-pattern>/worldtime</url-pattern>
	</servlet-mapping>
</web-app>